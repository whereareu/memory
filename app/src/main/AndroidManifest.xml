<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="com.android.launcher.permission.INSTALL_SHORTCUT" />

    <application
        android:name=".MemoryApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_launcher_foreground"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_foreground"
        android:supportsRtl="true"
        android:theme="@style/Theme.Memory">

        <!-- 闪屏页（主入口） -->
        <activity
            android:name=".Splash"
            android:exported="true"
            android:theme="@style/Theme.Memory">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- 长按应用图标显示的快捷方式 -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- 主页面Activity -->
        <activity
            android:name=".Main"
            android:exported="false"
            android:theme="@style/Theme.Memory" />

        <!-- 编辑Activity -->
        <activity
            android:name=".Edit"
            android:exported="false"
            android:theme="@style/Theme.Memory"/>

        <!-- 小部件Provider -->
        <!-- 质量 Widget -->
        <receiver
            android:name=".features.widget.widget.TextWidget1"
            android:exported="true"
            android:label="质量 Widget">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_1"/>
        </receiver>

        <!-- 名言 Widget -->
        <receiver
            android:name=".features.widget.widget.TextWidget2"
            android:exported="true"
            android:label="名言 Widget">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_2"/>
        </receiver>

        <!-- 日期计数器 Widget -->
        <receiver
            android:name=".features.widget.widget.TextWidget3"
            android:exported="true"
            android:label="日期计数器">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
                <action android:name="android.intent.action.DATE_CHANGED"/>
                <action android:name="android.intent.action.TIME_SET"/>
                <action android:name="android.intent.action.TIMEZONE_CHANGED"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info_3"/>
        </receiver>

        <!-- 通用 Widget (原始小部件) -->
        <receiver
            android:name=".features.widget.widget.TextWidget"
            android:exported="true"
            android:label="@string/widget0_description">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info"/>
        </receiver>

        <!-- 小部件配置Activity -->
        <activity
            android:name=".features.widget.configuration.WidgetConfigActivity"
            android:exported="false"
            android:theme="@style/Theme.Memory"/>

    </application>

</manifest>