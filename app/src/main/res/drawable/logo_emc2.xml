<!-- 方案3: 优化版极简E=mc²风格 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 背景：深空蓝 -->
    <path
        android:fillColor="#1B2631"
        android:pathData="M54,54 m-50,0 a50,50 0 1,1 100,0 a50,50 0 1,1 -100,0"/>

    <!-- 时空弯曲网格弧线 - 增强3D效果 -->
    <!-- 顶部弧线 -->
    <path
        android:strokeColor="#81D4FA"
        android:strokeWidth="2.5"
        android:strokeAlpha="0.8"
        android:fillColor="#00000000"
        android:pathData="M16,40 Q54,22 92,40" />

    <!-- 中上部弧线 -->
    <path
        android:strokeColor="#4FC3F7"
        android:strokeWidth="2.5"
        android:strokeAlpha="0.7"
        android:fillColor="#00000000"
        android:pathData="M16,52 Q54,34 92,52" />

    <!-- 中下部弧线（中心弯曲最明显）-->
    <path
        android:strokeColor="#29B6F6"
        android:strokeWidth="2.5"
        android:strokeAlpha="0.6"
        android:fillColor="#00000000"
        android:pathData="M16,64 Q54,82 92,64" />

    <!-- 底部弧线 -->
    <path
        android:strokeColor="#039BE5"
        android:strokeWidth="2.5"
        android:strokeAlpha="0.5"
        android:fillColor="#00000000"
        android:pathData="M16,76 Q54,58 92,76" />

    <!-- 测地线（最短路径轨迹）- 加粗并增强 -->
    <path
        android:strokeColor="#FFD54F"
        android:strokeWidth="4.5"
        android:fillColor="#00000000"
        android:pathData="M24,28 Q54,80 84,28"
        android:strokeLineCap="round" />

    <!-- 粒子本体 - 更大更醒目 -->
    <path
        android:fillColor="#FFEB3B"
        android:pathData="M54,48.5 m-5.5,0 a5.5,5.5 0 1,1 11,0 a5.5,5.5 0 1,1 -11,0"/>

    <!-- 内层光晕 - 强烈发光 -->
    <path
        android:fillColor="#FFEB3B"
        android:fillAlpha="0.5"
        android:pathData="M54,44 m-10,0 a10,10 0 1,1 20,0 a10,10 0 1,1 -20,0"/>

    <!-- 外层光晕 - 柔和扩散 -->
    <path
        android:fillColor="#FFEB3B"
        android:fillAlpha="0.2"
        android:pathData="M54,38 m-16,0 a16,16 0 1,1 32,0 a16,16 0 1,1 -32,0"/>

    <!-- 时间箭头 - 表示时间维度流动 -->
    <path
        android:strokeColor="#FF6B6B"
        android:strokeWidth="2.5"
        android:strokeAlpha="0.85"
        android:fillColor="#00000000"
        android:pathData="M54,82 L54,93 M49,89 L54,93 L59,89"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"/>

</vector>