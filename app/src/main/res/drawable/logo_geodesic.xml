        android:strokeAlpha="0.6"
        android:pathData="M20,35 Q54,50 88,35" />
    <path
        android:strokeColor="#4A9EFF"
        android:strokeWidth="1.5"
        android:strokeAlpha="0.6"
        android:pathData="M20,54 Q54,69 88,54" />
    <path
        android:strokeColor="#4A9EFF"
        android:strokeWidth="1.5"
        android:strokeAlpha="0.6"
        android:pathData="M20,73 Q54,88 88,73" />

    <!-- 纵向网格线 -->
    <path
        android:strokeColor="#4A9EFF"
        android:strokeWidth="1.5"
        android:strokeAlpha="0.4"
        android:pathData="M35,20 Q45,54 35,88" />
    <path
        android:strokeColor="#4A9EFF"
        android:strokeWidth="1.5"
