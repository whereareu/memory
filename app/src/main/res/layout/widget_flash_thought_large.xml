<?xml version="1.0" encoding="utf-8"?>
<!-- 4x4 闪现 Widget 布局 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FF000000">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="今日闪现"
            android:textSize="14sp"
            android:textColor="#B3FFFFFF"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/widget_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● 置顶"
            android:textSize="11sp"
            android:textColor="#FF4CAF50"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/thought_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="11sp"
            android:textColor="#80FFFFFF"/>
    </LinearLayout>

    <!-- 最新闪现内容 -->
    <TextView
        android:id="@+id/thought_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:maxLines="12"
        android:ellipsize="end"
        android:textSize="17sp"
        android:textColor="#FFFFFFFF"
        android:gravity="start|top"
        android:lineSpacingExtra="4dp"
        android:text="点击添加闪现"/>

    <!-- 分隔线 -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:src="#33FFFFFF"
        android:scaleType="fitXY"
        android:contentDescription="分隔线"/>

    <!-- 操作按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 快速添加按钮 -->
        <ImageButton
            android:id="@+id/btn_quick_add"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:src="@android:drawable/ic_input_add"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:tint="#FFFFFFFF"
            android:contentDescription="快速添加"/>

        <!-- 查看列表按钮 -->
        <ImageButton
            android:id="@+id/btn_view_list"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:tint="#FFFFFFFF"
            android:contentDescription="查看列表"/>
    </LinearLayout>
</LinearLayout>
